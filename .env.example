# Local Postgres with pgvector (docker compose up -d)
# Swap to Supabase connection string in production.
DATABASE_URL=postgres://caas:caas@localhost:5432/caas

# Anthropic (Claude agents)
ANTHROPIC_API_KEY=

# Google Gemini (vision extraction + text embeddings)
GEMINI_API_KEY=

# FashionCLIP — local Python microservice (uvicorn on :8001 by default)
FASHIONCLIP_URL=http://localhost:8001

# Mock data mode
# Set to true to force the frontend-facing app data to use mock implementations.
# Accepts: 1, true, yes, on
CAAS_USE_MOCK_DATA=false

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/callback
